{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022", "DOM"],
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "noEmit": true,
    "rootDir": "..",
    "baseUrl": ".",
    "paths": {
      "@e2e/pages/*": ["pages/*"],
      "@e2e/helpers/*": ["helpers/*"],
      "@e2e/constants/*": ["constants/*"],
      "@e2e/fixtures/*": ["fixtures/*"]
    }
  },
  "include": ["./**/*.ts", "../playwright.config.ts"],
  "exclude": ["../node_modules", "../src", "../build"]
}
